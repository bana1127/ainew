# Frontend environment variables
# Copy to .env.local for local development

# API base URL used in the browser
# Leave empty to use Next.js rewrites (/api/* → backend)
# Set to http://127.0.0.1:8001 to call backend directly (bypasses rewrite)
NEXT_PUBLIC_API_BASE_URL=

# Browser-visible app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend proxy target for Next.js rewrites (server-side only, NOT exposed to browser)
# Default: http://127.0.0.1:8001
NEXT_API_PROXY_TARGET=http://127.0.0.1:8001
