APP_NAME=ClubAgent
APP_ENV=development
DATABASE_URL=postgresql+psycopg://clubagent:clubagent@localhost:5433/clubagent

# CORS allowed origins (comma-separated)
# Local dev: http://localhost:3000
# External: https://agent.banawy.store
BACKEND_CORS_ORIGINS=http://localhost:3000,https://agent.banawy.store

UPLOAD_DIR=uploads
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MOCK_MODE=true
OPENAI_VISION_MODEL=

# Automation API token (optional)
# If set, automation endpoints require X-Automation-Token header
# Leave empty to allow unauthenticated automation calls (local dev only)
AUTOMATION_API_TOKEN=

# n8n Gmail notification integration
N8N_WEBHOOK_URL=
N8N_SECRET=
N8N_ENABLED=true
FRONTEND_URL=http://localhost:3000
